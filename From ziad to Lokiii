<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>From Ziad to Loki ❣️</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;600;900&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Cairo', sans-serif;
  overflow: hidden;
  background: black;
  color: white;
}

/* intro screen */
#intro {
  position: fixed;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, #ff4d6d, #000);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  z-index: 10;
}

#intro h1 {
  font-size: 40px;
  text-shadow: 0 0 20px #fff;
}

#intro button {
  margin-top: 20px;
  padding: 12px 30px;
  border-radius: 30px;
  border: none;
  background: white;
  color: #ff4d6d;
  font-weight: bold;
  cursor: pointer;
}

/* background */
.bg {
  position: fixed;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at top, #ff4d6d, transparent 60%),
              radial-gradient(circle at bottom, #6a00ff, transparent 60%),
              black;
  animation: glow 6s infinite alternate;
}

@keyframes glow {
  0% {filter: brightness(1);}
  100% {filter: brightness(1.4);}
}

/* main card */
.container {
  position: relative;
  z-index: 2;
  text-align: center;
  top: 10%;
  padding: 20px;
  display: none;
}

.card {
  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(15px);
  border-radius: 25px;
  padding: 30px;
  width: 85%;
  margin: auto;
  box-shadow: 0 0 50px rgba(255,77,109,0.4);
}

h1 {
  font-size: 40px;
  margin: 0;
}

.name {
  font-size: 32px;
  color: #ff4d6d;
  text-shadow: 0 0 20px #ff4d6d;
  margin: 10px 0;
}

.text {
  font-size: 18px;
  line-height: 1.8;
  min-height: 220px;
}

/* button */
button.play {
  margin-top: 20px;
  padding: 12px 28px;
  border: none;
  border-radius: 30px;
  background: #ff4d6d;
  color: white;
  font-weight: bold;
  cursor: pointer;
  box-shadow: 0 0 25px #ff4d6d;
}

/* hearts */
.heart {
  position: absolute;
  width: 14px;
  height: 14px;
  background: #ff4d6d;
  transform: rotate(45deg);
  animation: float 6s linear infinite;
}

.heart::before,
.heart::after {
  content: "";
  position: absolute;
  width: 14px;
  height: 14px;
  background: #ff4d6d;
  border-radius: 50%;
}

.heart::before { top: -7px; }
.heart::after { left: -7px; }

@keyframes float {
  0% {transform: translateY(100vh) rotate(45deg); opacity:1;}
  100% {transform: translateY(-10vh) rotate(45deg); opacity:0;}
}

/* fade */
.fade {
  animation: fade 2s ease forwards;
}

@keyframes fade {
  from {opacity: 0;}
  to {opacity: 1;}
}

</style>
</head>

<body>

<div id="intro">
  <h1>💖 For Someone Special 💖</h1>
  <h2>LOKI ❣️</h2>
  <button onclick="start()">Enter</button>
</div>

<div class="bg"></div>

<div class="container" id="main">

  <div class="card">

    <h1>From Ziad ❤️</h1>
    <div class="name">to LOKI ❣️</div>

    <div class="text" id="text"></div>

    <button class="play" onclick="play()">▶ Play Music</button>

  </div>

</div>

<iframe id="song" width="0" height="0"></iframe>

<script>

let msg = `
You are not just someone I love…
you are my peace, my home, my everything.

No matter what happens in life,
I will always choose you.

I will stay with you step by step,
through every moment, every feeling.

انتِ مش شخص عادي…
انتِ الحياة اللي بحس فيها إني عايش بجد.

وهفضل جنبك… مهما حصل ❤️
`;

let i = 0;

function type() {
  if (i < msg.length) {
    document.getElementById("text").innerHTML += msg[i];
    i++;
    setTimeout(type, 35);
  }
}

function start() {
  document.getElementById("intro").style.display = "none";
  document.getElementById("main").style.display = "block";
  type();
}

// music
function play() {
  document.getElementById("song").src =
  "https://www.youtube.com/embed/mpSDIWV6x4Y?autoplay=1";
}

// hearts
setInterval(() => {
  let h = document.createElement("div");
  h.className = "heart";
  h.style.left = Math.random()*100 + "vw";
  h.style.animationDuration = (3 + Math.random()*3) + "s";
  document.body.appendChild(h);
  setTimeout(()=>h.remove(),6000);
}, 150);

</script>

</body>
</html>
